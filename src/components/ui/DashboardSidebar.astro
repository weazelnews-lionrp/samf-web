---
interface Props {
	activePath: string
	role?: string
}

const { activePath, role = 'PUBLIC' } = Astro.props

const isStaff = role.startsWith('STAFF_')

// User Menu Links
const userLinks = [
	{
		label: 'Mi Panel',
		href: '/private/dashboard',
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layout-dashboard"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="10" rx="1"/><rect width="7" height="5" x="3" y="14" rx="1"/></svg>`,
	},
	{
		label: 'Trámites y Licencias',
		href: '/private/applications',
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>`,
	},
	{
		label: 'Homologar Vehículos',
		href: '/private/vehicles',
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-car"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>`,
	},
	{
		label: 'Buzón de Notificaciones',
		href: '/private/notifications',
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bell"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>`,
	},
]

// Add Director special links
if (role === 'DIRECTOR_ESCUDERIA' || role === 'STAFF_ADMIN' || role === 'STAFF_DIRECTOR_GENERAL') {
	userLinks.splice(2, 0, 
		{
			label: 'Mi Escudería',
			href: '/private/team/my-team',
			icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
		},
		{
			label: 'Boletines de Prensa',
			href: '/private/team/bulletins',
			icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-newspaper"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>`,
		}
	)
}

// Admin Intranet Links
const adminLinks = [
	{
		label: 'Bandeja de Solicitudes',
		href: '/admin/requests',
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-inbox"><polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>`,
	},
	{
		label: 'Gestión de Ligas/GP',
		href: '/admin/competitions',
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trophy"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.45 1-1 1H4v2h16v-2h-5c-.55 0-1-.45-1-1v-2.34"/><path d="M12 2a6 6 0 0 0-6 6v5a6 6 0 0 0 12 0V8a6 6 0 0 0-6-6z"/></svg>`,
	},
	{
		label: 'Seguridad y Pistas',
		href: '/admin/security',
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-alert"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.5 3.8 17 5 19 5a1 1 0 0 1 1 1z"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>`,
	},
	{
		label: 'Régimen Disciplinario',
		href: '/admin/discipline',
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-gavel"><path d="m14 5-3-3H4v7l3 3"/><path d="m14 5 5 5-8 8H6v-5l8-8Z"/><path d="M16 16v6"/><path d="M19 22H13"/></svg>`,
	},
]
---

<aside class="w-full md:w-64 shrink-0 bg-slate-dark border border-slate-border rounded-xl p-4 flex flex-col gap-6 h-fit font-racing tracking-wider uppercase">
	<!-- Panel Selection Toggle -->
	{isStaff && (
		<div class="grid grid-cols-2 bg-slate-black p-1 rounded-lg border border-slate-border text-center text-xs">
			<a
				href="/private/dashboard"
				class={`py-2 rounded-md transition-colors ${!activePath.startsWith('/admin') ? 'bg-slate-gray text-white font-bold' : 'text-text-muted hover:text-white'}`}
			>
				Deportiva
			</a>
			<a
				href="/admin/requests"
				class={`py-2 rounded-md transition-colors ${activePath.startsWith('/admin') ? 'bg-brand-red text-white font-bold' : 'text-text-muted hover:text-white'}`}
			>
				Intranet
			</a>
		</div>
	)}

	<div class="flex flex-col gap-1.5">
		<p class="text-[10px] text-text-muted font-bold tracking-widest px-3 mb-2">
			{!activePath.startsWith('/admin') ? 'Gestión de Deportista' : 'Panel de Control SAMF'}
		</p>
		
		{(!activePath.startsWith('/admin') ? userLinks : adminLinks).map((link) => {
			const isActive = activePath === link.href || (link.href !== '/private/dashboard' && activePath.startsWith(link.href))
			const activeStyles = activePath.startsWith('/admin') 
				? 'bg-brand-red/15 text-brand-red border-l-2 border-brand-red font-bold' 
				: 'bg-slate-gray/50 text-white border-l-2 border-brand-red font-bold'
			const inactiveStyles = 'text-text-muted hover:text-white hover:bg-slate-gray/20'

			return (
				<a
					href={link.href}
					class={`flex items-center gap-3 px-3 py-3 rounded-lg text-xs transition-all duration-150 ${isActive ? activeStyles : inactiveStyles}`}
				>
					<span class={isActive ? 'text-brand-red' : 'text-text-muted'}>
						<Fragment set:html={link.icon} />
					</span>
					<span>{link.label}</span>
				</a>
			)
		})}
	</div>

	<!-- Bottom Section -->
	<div class="border-t border-slate-border pt-4 flex flex-col gap-2">
		<a
			href="/account"
			class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-xs text-text-muted hover:text-white hover:bg-slate-gray/25 transition-colors"
		>
			<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user-cog"><circle cx="18" cy="15" r="3"/><circle cx="9" cy="7" r="4"/><path d="M10 15H6a4 4 0 0 0-4 4v2"/><path d="m21.7 16.4-.9-.3"/><path d="m15.2 13.9-.9-.3"/><path d="m16.6 18.7.3-.9"/><path d="m19.4 12.2.3-.9"/><path d="m20 13.7.7-.7"/><path d="m16 16.3.7-.7"/><path d="m20.9 17.1.8.8"/><path d="m15.1 12.9.8.8"/></svg>
			<span>Personajes</span>
		</a>
		<a
			href="/api/auth/logout"
			class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-xs text-red-400 hover:text-red-300 hover:bg-red-500/10 transition-colors"
		>
			<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-log-out"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
			<span>Cerrar Sesión</span>
		</a>
	</div>
</aside>
