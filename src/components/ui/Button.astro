---
interface Props {
	variant?: 'primary' | 'secondary' | 'danger' | 'outline'
	size?: 'sm' | 'md' | 'lg'
	href?: string
	class?: string
	id?: string
	disabled?: boolean
	type?: 'button' | 'submit' | 'reset'
	[key: string]: any
}

const {
	variant = 'primary',
	size = 'md',
	href,
	class: className = '',
	id,
	disabled = false,
	type = 'button',
	...rest
} = Astro.props

const baseStyles = 'inline-flex items-center justify-center font-racing tracking-wider uppercase font-bold rounded-lg transition-all duration-200 cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-red disabled:opacity-50 disabled:pointer-events-none select-none hover:-translate-y-0.5 active:translate-y-0'

const variants = {
	primary: 'bg-brand-red hover:bg-brand-red-light active:bg-brand-red-dark text-white shadow-md shadow-brand-red/10 hover:shadow-brand-red/20',
	secondary: 'bg-slate-gray hover:bg-slate-normal text-white border border-slate-border',
	danger: 'bg-red-600 hover:bg-red-500 active:bg-red-700 text-white shadow-md shadow-red-600/10 hover:shadow-red-600/20',
	outline: 'bg-transparent border border-slate-border text-text-secondary hover:text-white hover:bg-slate-gray/30 hover:border-text-muted',
}

const sizes = {
	sm: 'text-xs px-3 py-1.5 gap-1.5',
	md: 'text-sm px-4 py-2.5 gap-2',
	lg: 'text-base px-6 py-3.5 gap-2.5',
}

const combinedClasses = `${baseStyles} ${variants[variant]} ${sizes[size]} ${className}`
---

{
	href ? (
		<a href={href} class={combinedClasses} id={id} {...rest}>
			<slot />
		</a>
	) : (
		<button type={type} class={combinedClasses} id={id} disabled={disabled} {...rest}>
			<slot />
		</button>
	)
}
