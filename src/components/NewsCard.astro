---
import { ChevronRight } from '@lucide/astro/icons'

interface Props {
	title: string
	description?: string
	image: string
	category: string
	href: string
	isMain?: boolean
}

const { title, description, image, category, href, isMain = false } = Astro.props
---

{
	isMain ? (
		<article class="bg-slate-dark border-slate-border/50 hover:border-slate-border group flex flex-col overflow-hidden rounded-xl border transition-all duration-300">
			<div class="relative aspect-video overflow-hidden">
				<img
					src={image}
					alt={title}
					class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
				/>
				<div class="from-slate-dark absolute inset-0 bg-linear-to-t via-transparent to-transparent opacity-60" />
			</div>
			<div class="flex grow flex-col gap-2 p-5">
				<span class="text-brand-red font-racing text-[10px] font-bold tracking-[0.15em] uppercase">
					{category}
				</span>
				<h3 class="font-racing group-hover:text-brand-red text-lg leading-tight font-bold tracking-wide text-white uppercase transition-colors">
					{title}
				</h3>
				{description && (
					<p class="text-text-muted mt-1 text-xs leading-relaxed">{description}</p>
				)}
				<a
					href={href}
					class="text-brand-red group-hover:text-brand-red-light font-racing mt-auto inline-flex items-center gap-1 pt-3 text-[11px] font-bold tracking-widest uppercase transition-colors">
					<span>Leer más</span>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						fill="none"
						viewBox="0 0 24 24"
						stroke-width="2.5"
						stroke="currentColor"
						class="h-3.5 w-3.5 transition-transform duration-200 group-hover:translate-x-1">
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
						/>
					</svg>
				</a>
			</div>
		</article>
	) : (
		<article class="bg-slate-dark border-slate-border/50 hover:border-slate-border group flex h-full flex-col overflow-hidden rounded-xl border transition-all duration-300">
			<div class="relative aspect-16/10 overflow-hidden">
				<img
					src={image}
					alt={title}
					class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
				/>
				<div class="from-slate-dark/80 absolute inset-0 bg-linear-to-t via-transparent to-transparent opacity-60" />
			</div>
			<div class="flex grow flex-col gap-1.5 p-4">
				<span class="text-brand-red font-racing text-[9px] font-bold tracking-[0.12em] uppercase">
					{category}
				</span>
				<h4 class="font-racing group-hover:text-brand-red line-clamp-2 text-xs leading-tight font-bold tracking-wide text-white uppercase transition-colors">
					{title}
				</h4>
				<a
					href={href}
					class="text-brand-red group-hover:text-brand-red-light font-racing mt-auto inline-flex items-center gap-1 pt-2 text-[9px] font-bold tracking-widest uppercase transition-colors">
					<span>Leer más</span>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						fill="none"
						viewBox="0 0 24 24"
						stroke-width="2.5"
						stroke="currentColor"
						class="h-3 w-3 transition-transform duration-200 group-hover:translate-x-0.5">
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
						/>
					</svg>
				</a>
			</div>
		</article>
	)
}
