---
import Layout from '@layouts/Layout.astro'
import Card from '@/components/ui/Card.astro'
import Button from '@/components/ui/Button.astro'
import StatusBadge from '@/components/ui/StatusBadge.astro'
import DashboardSidebar from '@/components/ui/DashboardSidebar.astro'

const { user, citizenid, character } = Astro.locals

// Auth protection & Role restriction (Staff only)
if (!user || !citizenid || !character) {
	return Astro.redirect('/account')
}

if (!user.role.startsWith('STAFF_')) {
	return Astro.redirect('/private/dashboard')
}

// Fetch pending requests
let requests = []
let errorMsg = ''
try {
	const apiUrl = new URL('/api/admin/requests?status=PENDING', Astro.url)
	const res = await fetch(apiUrl, {
		headers: { Cookie: Astro.request.headers.get('cookie') || '' }
	})
	const data = await res.json()
	if (data.success) {
		requests = data.requests || []
	} else {
		errorMsg = data.error?.message || 'Error al cargar trámites.'
	}
} catch (err) {
	console.error('Error fetching admin requests:', err)
	errorMsg = 'Error de conexión con la API de administración.'
}
---

<Layout title="Bandeja de Solicitudes | SAMF Intranet" description="Intranet administrativa de la SAMF para la resolución de licencias e inscripciones.">
	<div class="max-w-[1440px] mx-auto px-4 md:px-8 py-12 flex flex-col md:flex-row gap-8">
		<!-- Sidebar Menu -->
		<DashboardSidebar activePath="/admin/requests" role={user.role} />

		<!-- Main Panel Content -->
		<div class="flex-1 flex flex-col gap-6">
			<!-- Header Card -->
			<Card glow>
				<div class="flex items-center gap-3 mb-2">
					<span class="w-6 h-[2px] bg-brand-red rounded-sm"></span>
					<h1 class="text-xl font-bold uppercase tracking-wider font-racing text-white">Bandeja de Trámites Pendientes</h1>
				</div>
				<p class="text-xs text-text-muted">
					Expedientes y solicitudes enviados por corredores y directores de equipo en espera de resolución.
				</p>
			</Card>

			{errorMsg && (
				<div class="bg-red-500/10 border border-red-500/30 rounded-lg p-4 text-xs text-red-400">
					{errorMsg}
				</div>
			)}

			<!-- List of requests -->
			{requests.length === 0 ? (
				<Card class="text-center py-16 text-text-muted">
					<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check-check mx-auto mb-3 opacity-30"><path d="M2 17 6 21 16 11"/><path d="m22 11-10 10-1.5-1.5"/></svg>
					No hay solicitudes pendientes de resolución. ¡Bandeja limpia!
				</Card>
			) : (
				<div class="flex flex-col gap-6">
					{requests.map((req: any) => (
						<Card class="bg-slate-dark/50 border-slate-border flex flex-col gap-4">
							<!-- Header of request card -->
							<div class="flex flex-col sm:flex-row justify-between sm:items-center gap-2 border-b border-slate-border/50 pb-2.5">
								<div>
									<span class="text-[9px] bg-brand-red/10 text-brand-red border border-brand-red/20 px-2 py-0.5 rounded font-mono font-bold tracking-wide uppercase">
										{req.type}
									</span>
									<span class="text-xs font-bold text-white font-mono ml-2">ID: {req.id}</span>
								</div>
								<span class="text-[10px] text-text-muted font-mono">
									Presentado: {new Date(req.createdAt).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' })}
								</span>
							</div>

							<!-- Details / Payload of request -->
							<div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-xs font-mono">
								<div class="flex flex-col gap-2">
									<div class="border-b border-slate-border/20 pb-1.5">
										<span class="text-text-muted">Solicitante:</span>
										<span class="text-white font-bold ml-2">{req.userName}</span>
									</div>
									<div class="border-b border-slate-border/20 pb-1.5">
										<span class="text-text-muted">Citizen ID:</span>
										<span class="text-white ml-2">{req.userId}</span>
									</div>
									
									{req.paymentProofUrl && (
										<div>
											<span class="text-text-muted">Justificante Pago:</span>
											<a 
												href={req.paymentProofUrl} 
												target="_blank" 
												class="text-brand-red hover:underline ml-2 font-bold"
											>
												Ver Documento
											</a>
										</div>
									)}
								</div>

								<!-- Type-specific payload details -->
								<div class="bg-slate-black/35 rounded-lg p-4 border border-slate-border/40">
									<span class="text-[9px] text-text-muted uppercase tracking-wider block mb-2 font-racing">Campos del Formulario</span>
									
									{req.type === 'DRIVER_LICENSE' && (
										<div class="flex flex-col gap-1.5">
											<span class="text-white font-bold">Nombre: {req.payload.fullName}</span>
											<span class="text-white">Escudería: {req.payload.targetTeamId}</span>
											<span>DNI: <a href={req.payload.identityDocUrl} target="_blank" class="text-brand-red hover:underline">Ver DNI</a></span>
											<span>Médico: <a href={req.payload.medicalCertificateUrl} target="_blank" class="text-brand-red hover:underline">Ver Certificado</a></span>
										</div>
									)}

									{req.type === 'TEAM_REGISTRATION' && (
										<div class="flex flex-col gap-1.5">
											<span class="text-white font-bold">Nombre Escudería: {req.payload.name}</span>
											<span class="text-white flex items-center gap-1.5">
												Badge: 
												<span class="w-3.5 h-3.5 rounded border border-white/20" style={{ backgroundColor: req.payload.visualBadge }}></span>
												{req.payload.visualBadge}
											</span>
											<span>Pilotos Iniciales: {req.payload.initialDrivers?.join(', ') || 'Ninguno'}</span>
											<span>Logo: <a href={req.payload.logoUrl} target="_blank" class="text-brand-red hover:underline">Ver Imagen</a></span>
										</div>
									)}

									{req.type === 'DELEGATED_EVENT' && (
										<div class="flex flex-col gap-1.5">
											<span class="text-white font-bold">Título: {req.payload.eventTitle}</span>
											<span class="text-white">Organiza: {req.payload.organizerName}</span>
											<span class="text-text-secondary leading-normal block mt-1">Desc: {req.payload.description}</span>
											<span class="mt-2 text-[10px] flex gap-3">
												<a href={req.payload.routeLayoutUrl} target="_blank" class="text-brand-red hover:underline">Plano</a>
												<a href={req.payload.securityPlanUrl} target="_blank" class="text-brand-red hover:underline">Plan Seg</a>
												<a href={req.payload.liabilityInsuranceUrl} target="_blank" class="text-brand-red hover:underline">Seguro</a>
											</span>
										</div>
									)}

									{req.type === 'CATALOG_INCLUSION' && (
										<div class="flex flex-col gap-1.5">
											<span class="text-white font-bold">Vehículo: {req.payload.brand} {req.payload.model}</span>
											<span class="text-white">Clase: {req.payload.category}</span>
											<span class="text-text-secondary">Specs: {req.payload.technicalSpecs}</span>
										</div>
									)}

									{req.type === 'VEHICLE_HOMOLOGATION' && (
										<div class="flex flex-col gap-1.5">
											<span class="text-white font-bold">Modelo ID: {req.payload.modelId}</span>
											<span class="text-white">Bastidor/VIN: {req.payload.chassisNumber}</span>
											
											<div class="grid grid-cols-2 gap-x-2 gap-y-0.5 mt-2 text-[10px] text-text-muted uppercase">
												<span class={req.payload.safetyChecks?.rollCage ? 'text-emerald-400 font-bold' : 'text-red-400'}>
													{req.payload.safetyChecks?.rollCage ? '✓ Jaula' : '✗ Jaula'}
												</span>
												<span class={req.payload.safetyChecks?.fireExtinguisher ? 'text-emerald-400 font-bold' : 'text-red-400'}>
													{req.payload.safetyChecks?.fireExtinguisher ? '✓ Extintor' : '✗ Extintor'}
												</span>
												<span class={req.payload.safetyChecks?.harnessFourPoints ? 'text-emerald-400 font-bold' : 'text-red-400'}>
													{req.payload.safetyChecks?.harnessFourPoints ? '✓ Arnés' : '✗ Arnés'}
												</span>
												<span class={req.payload.safetyChecks?.certifiedSeat ? 'text-emerald-400 font-bold' : 'text-red-400'}>
													{req.payload.safetyChecks?.certifiedSeat ? '✓ Backet' : '✗ Backet'}
												</span>
												<span class={req.payload.safetyChecks?.controlECU ? 'text-emerald-400 font-bold' : 'text-red-400'}>
													{req.payload.safetyChecks?.controlECU ? '✓ ECU' : '✗ ECU'}
												</span>
												<span class="text-white font-bold">{req.payload.safetyChecks?.tiresCategory}</span>
											</div>
										</div>
									)}
								</div>
							</div>

							<!-- Action Buttons / Resolution Form -->
							<div class="border-t border-slate-border/40 pt-4 flex flex-col md:flex-row justify-end gap-3" data-request-id={req.id}>
								<!-- Approve Action -->
								<Button type="button" variant="primary" class="approve-btn text-xs px-3.5 py-1.5 bg-emerald-600 hover:bg-emerald-500 active:bg-emerald-700 shadow-none">
									Aprobar Trámite
								</Button>

								<!-- Reject Trigger -->
								<div class="flex flex-col md:flex-row gap-2 w-full md:w-auto">
									<input 
										type="text" 
										placeholder="Motivo de rechazo..." 
										class="rejection-reason-input bg-slate-black/50 border border-slate-border rounded px-3 py-1.5 text-xs text-white placeholder:text-text-muted/40 focus:outline-none focus:border-brand-red w-full md:w-60"
									/>
									<Button type="button" variant="danger" class="reject-btn text-xs px-3.5 py-1.5 shrink-0">
										Rechazar
									</Button>
								</div>
							</div>
						</Card>
					))}
				</div>
			)}
		</div>
	</div>
</Layout>

<script>
	document.addEventListener('astro:page-load', () => {
		const cards = document.querySelectorAll('[data-request-id]');
		
		cards.forEach(card => {
			const reqId = card.getAttribute('data-request-id');
			const approveBtn = card.querySelector('.approve-btn');
			const rejectBtn = card.querySelector('.reject-btn');
			const reasonInput = card.querySelector('.rejection-reason-input') as HTMLInputElement;

			if (approveBtn && reqId) {
				approveBtn.addEventListener('click', async () => {
					if (!confirm(`¿Estás seguro de que deseas APROBAR la solicitud ${reqId}?`)) return;
					
					try {
						const res = await fetch(`/api/admin/requests/${reqId}/resolve`, {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({ status: 'APPROVED' })
						});
						
						const data = await res.json();
						if (data.success) {
							alert('Solicitud aprobada con éxito.');
							window.location.reload();
						} else {
							alert('Error: ' + (data.error?.message || 'Error al resolver solicitud.'));
						}
					} catch (err) {
						console.error('Error resolving request:', err);
						alert('Error de conexión.');
					}
				});
			}

			if (rejectBtn && reqId && reasonInput) {
				rejectBtn.addEventListener('click', async () => {
					const reason = reasonInput.value.trim();
					if (!reason) {
						alert('Debe proporcionar un motivo de rechazo.');
						reasonInput.focus();
						return;
					}

					if (!confirm(`¿Deseas RECHAZAR la solicitud ${reqId} por: "${reason}"?`)) return;

					try {
						const res = await fetch(`/api/admin/requests/${reqId}/resolve`, {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({ status: 'REJECTED', rejectionReason: reason })
						});
						
						const data = await res.json();
						if (data.success) {
							alert('Solicitud rechazada con éxito.');
							window.location.reload();
						} else {
							alert('Error: ' + (data.error?.message || 'Error al resolver solicitud.'));
						}
					} catch (err) {
						console.error('Error resolving request:', err);
						alert('Error de conexión.');
					}
				});
			}
		});
	});
</script>
