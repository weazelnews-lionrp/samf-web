---
import Layout from '@layouts/Layout.astro'
import Card from '@/components/ui/Card.astro'
import Button from '@/components/ui/Button.astro'
import Input from '@/components/ui/Input.astro'
import DashboardSidebar from '@/components/ui/DashboardSidebar.astro'

const { user, citizenid, character } = Astro.locals

// Auth protection & Role check (Staff Inspector only)
if (!user || !citizenid || !character) {
	return Astro.redirect('/account')
}

if (user.role !== 'STAFF_INSPECTOR' && user.role !== 'STAFF_ADMIN' && user.role !== 'STAFF_DIRECTOR_GENERAL') {
	return Astro.redirect('/private/dashboard')
}

// 1. Fetch GPs for dropdown
let gpOptions = []
try {
	const apiUrl = new URL('/api/calendar', Astro.url)
	const res = await fetch(apiUrl)
	const data = await res.json()
	if (data.success) {
		gpOptions = (data.events || []).map((e: any) => ({
			value: e.id,
			label: e.name
		}))
	}
} catch (err) {
	console.error('Error fetching GPs in controls form:', err)
}

// 2. Fetch all drivers for dropdown
let driverOptions = []
try {
	const apiUrl = new URL('/api/drivers', Astro.url)
	const res = await fetch(apiUrl)
	const data = await res.json()
	if (data.success) {
		driverOptions = (data.drivers || []).map((d: any) => ({
			value: d.id,
			label: `${d.name} (${d.teamName || 'Sin Escudería'})`
		}))
	}
} catch (err) {
	console.error('Error fetching drivers in controls form:', err)
}

const typeOptions = [
	{ value: 'PRE_EVENT', label: 'PRE-EVENTO (Antes de carrera)' },
	{ value: 'POST_EVENT', label: 'POST-EVENTO (Después de carrera)' }
]

const resultOptions = [
	{ value: 'NEGATIVE', label: 'NEGATIVO (Apto para competir)' },
	{ value: 'POSITIVE', label: 'POSITIVO (No apto)' }
]
---

<Layout title="Controles de Sustancias | SAMF Intranet" description="Registrar controles de alcohol y sustancias obligatorios pre y post-carrera a pilotos.">
	<div class="max-w-[1440px] mx-auto px-4 md:px-8 py-12 flex flex-col md:flex-row gap-8">
		<!-- Sidebar Menu -->
		<DashboardSidebar activePath="/admin/security" role={user.role} />

		<!-- Main Panel Content -->
		<div class="flex-1 flex flex-col gap-6">
			<!-- Back Link -->
			<div>
				<Button href="/admin/security" variant="outline" size="sm" class="flex items-center gap-2">
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
					Volver a Seguridad
				</Button>
			</div>

			<!-- Form Card -->
			<Card glow>
				<div class="flex items-center gap-3 mb-2 border-b border-slate-border/50 pb-3">
					<span class="w-6 h-[2px] bg-brand-red rounded-sm"></span>
					<h1 class="text-xl font-bold uppercase tracking-wider font-racing text-white">Registrar Control de Alcohol y Drogas (Art. 16.1)</h1>
				</div>
				
				<p class="text-xs text-text-muted mb-8 leading-relaxed">
					Introduce los valores analíticos obtenidos de la prueba obligatoria. 
					<span class="text-brand-red font-bold uppercase tracking-wide block mt-2">Atención (Art. 16.9):</span>
					El registro de un positivo (drogas POSITIVO o nivel alcohol &gt; 0.0) suspenderá la licencia de piloto y abrirá expediente disciplinario automáticamente de forma confidencial.
				</p>

				<form id="substance-control-form" class="flex flex-col gap-6">
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						<Input 
							label="Gran Premio / Evento" 
							type="select" 
							name="gpId" 
							placeholder="Selecciona un GP..."
							options={gpOptions}
							required 
						/>
						<Input 
							label="Piloto Examinado" 
							type="select" 
							name="driverId" 
							placeholder="Selecciona piloto..."
							options={driverOptions}
							required 
						/>
					</div>

					<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
						<Input 
							label="Tipo de Control" 
							type="select" 
							name="testType" 
							options={typeOptions}
							required 
						/>
						<Input 
							label="Nivel de Alcohol (mg/L)" 
							type="number" 
							name="alcoholLevel" 
							value="0.0"
							step="0.01"
							min="0"
							required 
						/>
						<Input 
							label="Resultado de Drogas" 
							type="select" 
							name="drugsResult" 
							options={resultOptions}
							required 
						/>
					</div>

					<div class="flex justify-end gap-3 mt-4 border-t border-slate-border/30 pt-6">
						<Button type="button" variant="outline" href="/admin/security">
							Cancelar
						</Button>
						<Button type="submit" variant="primary" id="submit-btn">
							Registrar Analítica
						</Button>
					</div>
				</form>
			</Card>
		</div>
	</div>
</Layout>

<script>
	document.addEventListener('astro:page-load', () => {
		const form = document.getElementById('substance-control-form') as HTMLFormElement;
		const submitBtn = document.getElementById('submit-btn');

		if (form) {
			form.addEventListener('submit', async (e) => {
				e.preventDefault();

				if (submitBtn) {
					submitBtn.setAttribute('disabled', 'true');
					submitBtn.textContent = 'Guardando...';
				}

				const formData = new FormData(form);
				const payload = {
					gpId: formData.get('gpId'),
					driverId: formData.get('driverId'),
					testType: formData.get('testType'),
					alcoholLevel: parseFloat(formData.get('alcoholLevel') as string || '0'),
					drugsResult: formData.get('drugsResult'),
				};

				try {
					const res = await fetch('/api/private/user/../../admin/security/substance-controls', {
						method: 'POST',
						headers: {
							'Content-Type': 'application/json'
						},
						body: JSON.stringify(payload)
					});

					const data = await res.json();
					if (data.success) {
						let msg = data.message || 'Control de sustancias registrado.';
						if (data.triggerAction?.licenseSuspended) {
							msg += '\n\nATENCIÓN: Se detectaron sustancias. La licencia del piloto ha sido SUSPENDIDA y se ha abierto expediente disciplinario automáticamente.';
						}
						alert(msg);
						window.location.href = '/admin/security';
					} else {
						alert('Error: ' + (data.error?.message || 'Error desconocido.'));
						if (submitBtn) {
							submitBtn.removeAttribute('disabled');
							submitBtn.textContent = 'Registrar Analítica';
						}
					}
				} catch (err) {
					console.error('Error submitting substance control:', err);
					alert('Error de red en el servidor.');
					if (submitBtn) {
						submitBtn.removeAttribute('disabled');
						submitBtn.textContent = 'Registrar Analítica';
					}
				}
			});
		}
	});
</script>
