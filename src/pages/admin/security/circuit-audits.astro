---
import Layout from '@layouts/Layout.astro'
import Card from '@/components/ui/Card.astro'
import Button from '@/components/ui/Button.astro'
import Input from '@/components/ui/Input.astro'
import DashboardSidebar from '@/components/ui/DashboardSidebar.astro'

const { user, citizenid, character } = Astro.locals

// Auth protection & Role check (Staff Inspector only)
if (!user || !citizenid || !character) {
	return Astro.redirect('/account')
}

if (user.role !== 'STAFF_INSPECTOR' && user.role !== 'STAFF_ADMIN' && user.role !== 'STAFF_DIRECTOR_GENERAL') {
	return Astro.redirect('/private/dashboard')
}

// Fetch circuits for dropdown
let circuitOptions = []
try {
	const apiUrl = new URL('/api/admin/security/circuits', Astro.url)
	const res = await fetch(apiUrl)
	const data = await res.json()
	if (data.success) {
		circuitOptions = (data.circuits || []).map((c: any) => ({
			value: c.id,
			label: `${c.name} (${c.location})`
		}))
	}
} catch (err) {
	console.error('Error fetching circuits for audit form:', err)
}

const passOptions = [
	{ value: 'true', label: 'APROBADO / HOMOLOGADO' },
	{ value: 'false', label: 'SUSPENDIDO / DEFICIENTE' }
]
---

<Layout title="Auditoría de Pistas | SAMF Intranet" description="Registrar auditoría técnica de seguridad en los circuitos homologados por la SAMF.">
	<div class="max-w-[1440px] mx-auto px-4 md:px-8 py-12 flex flex-col md:flex-row gap-8">
		<!-- Sidebar Menu -->
		<DashboardSidebar activePath="/admin/security" role={user.role} />

		<!-- Main Panel Content -->
		<div class="flex-1 flex flex-col gap-6">
			<!-- Back Link -->
			<div>
				<Button href="/admin/security" variant="outline" size="sm" class="flex items-center gap-2">
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
					Volver a Seguridad
				</Button>
			</div>

			<!-- Form Card -->
			<Card glow>
				<div class="flex items-center gap-3 mb-2 border-b border-slate-border/50 pb-3">
					<span class="w-6 h-[2px] bg-brand-red rounded-sm"></span>
					<h1 class="text-xl font-bold uppercase tracking-wider font-racing text-white">Registrar Auditoría Anual de Circuito (Art. 6.7)</h1>
				</div>
				
				<p class="text-xs text-text-muted mb-8 leading-relaxed">
					Introduce la fecha de inspección física y el dictamen técnico de homologación. Al inhabilitar una pista, se inhabilitará su uso en el calendario de carreras inmediatamente.
				</p>

				<form id="circuit-audit-form" class="flex flex-col gap-6">
					<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
						<Input 
							label="Circuito de Inspección" 
							type="select" 
							name="circuitId" 
							placeholder="Selecciona un circuito..."
							options={circuitOptions}
							required 
						/>
						<Input 
							label="Fecha de Inspección" 
							type="text" 
							name="inspectedAt" 
							placeholder="Ej. YYYY-MM-DD"
							value={new Date().toISOString().split('T')[0]}
							required 
						/>
						<Input 
							label="Dictamen del Inspector" 
							type="select" 
							name="passed" 
							options={passOptions}
							required 
						/>
					</div>

					<Input 
						label="Observaciones de Seguridad Pista" 
						type="textarea" 
						name="observations" 
						placeholder="Indica el estado del asfalto, barreras de protección tec-pro, escapatorias, puestos de comisarios..." 
					/>

					<div class="flex justify-end gap-3 mt-4 border-t border-slate-border/30 pt-6">
						<Button type="button" variant="outline" href="/admin/security">
							Cancelar
						</Button>
						<Button type="submit" variant="primary" id="submit-btn">
							Registrar Dictamen
						</Button>
					</div>
				</form>
			</Card>
		</div>
	</div>
</Layout>

<script>
	document.addEventListener('astro:page-load', () => {
		const form = document.getElementById('circuit-audit-form') as HTMLFormElement;
		const submitBtn = document.getElementById('submit-btn');

		if (form) {
			form.addEventListener('submit', async (e) => {
				e.preventDefault();

				if (submitBtn) {
					submitBtn.setAttribute('disabled', 'true');
					submitBtn.textContent = 'Guardando...';
				}

				const formData = new FormData(form);
				const payload = {
					circuitId: formData.get('circuitId'),
					inspectedAt: formData.get('inspectedAt'),
					passed: formData.get('passed') === 'true',
					observations: formData.get('observations'),
					auditReportUrl: ''
				};

				try {
					const res = await fetch('/api/admin/security/circuit-audits', {
						method: 'POST',
						headers: {
							'Content-Type': 'application/json'
						},
						body: JSON.stringify(payload)
					});

					const data = await res.json();
					if (data.success) {
						alert(data.message || 'Auditoría registrada correctamente.');
						window.location.href = '/calendar';
					} else {
						alert('Error: ' + (data.error?.message || 'Error desconocido.'));
						if (submitBtn) {
							submitBtn.removeAttribute('disabled');
							submitBtn.textContent = 'Registrar Dictamen';
						}
					}
				} catch (err) {
					console.error('Error submitting circuit audit:', err);
					alert('Error de red en el servidor.');
					if (submitBtn) {
						submitBtn.removeAttribute('disabled');
						submitBtn.textContent = 'Registrar Dictamen';
					}
				}
			});
		}
	});
</script>
