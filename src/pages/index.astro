---
import Layout from '@layouts/Layout.astro'
import Hero from '@components/Hero.astro'
import Shortcuts from '@components/Shortcuts.astro'
import FeaturedNews from '@components/FeaturedNews.astro'
import UpcomingRaces from '@components/UpcomingRaces.astro'
import FederationWidget from '@components/FederationWidget.astro'
---

<Layout title="San Andreas Motorsports Federation">
	<Hero />
	<Shortcuts />

	<!-- Main Content Section (Three Columns) -->
	<section class="max-w-[1440px] mx-auto px-4 md:px-8 py-16 grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-8 bg-slate-black">
		<FeaturedNews />
		<UpcomingRaces />
		<FederationWidget />
	</section>
</Layout>
