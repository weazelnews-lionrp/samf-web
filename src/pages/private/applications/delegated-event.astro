---
import Layout from '@layouts/Layout.astro'
import Card from '@/components/ui/Card.astro'
import Button from '@/components/ui/Button.astro'
import Input from '@/components/ui/Input.astro'
import DashboardSidebar from '@/components/ui/DashboardSidebar.astro'

const { user, citizenid, character } = Astro.locals

// Auth protection
if (!user || !citizenid || !character) {
	return Astro.redirect('/account')
}
---

<Layout title="Autorización de Eventos | SAMF" description="Trámite oficial para solicitar autorización delegada para carreras y rallys urbanos (Art. 10bis).">
	<div class="max-w-[1440px] mx-auto px-4 md:px-8 py-12 flex flex-col md:flex-row gap-8">
		<!-- Sidebar Menu -->
		<DashboardSidebar activePath="/private/applications" role={user.role} />

		<!-- Main Panel Content -->
		<div class="flex-1 flex flex-col gap-6">
			<!-- Back Link -->
			<div>
				<Button href="/private/applications" variant="outline" size="sm" class="flex items-center gap-2">
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
					Volver a Trámites
				</Button>
			</div>

			<!-- Form Card -->
			<Card glow>
				<div class="flex items-center gap-3 mb-2 border-b border-slate-border/50 pb-3">
					<span class="w-6 h-[2px] bg-brand-red rounded-sm"></span>
					<h1 class="text-xl font-bold uppercase tracking-wider font-racing text-white">Autorización Delegada para Eventos (Art. 10bis.2)</h1>
				</div>
				
				<p class="text-xs text-text-muted mb-8 leading-relaxed">
					Solicitud dirigida a promotores privados para carreras o rallys urbanos. Deberá presentarse con un mínimo de <strong>10 días de antelación</strong> al inicio del evento (Art. 10bis.2).
				</p>

				<form id="delegated-event-form" class="flex flex-col gap-6">
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						<Input 
							label="Nombre del Organizador o Promotora" 
							type="text" 
							name="organizerName" 
							placeholder="Ej. Los Santos Racing Association" 
							required 
						/>
						<Input 
							label="Título del Evento Competición" 
							type="text" 
							name="eventTitle" 
							placeholder="Ej. I Rally de Tierra Sandy Shores" 
							required 
						/>
					</div>

					<Input 
						label="Descripción y Detalles del Evento" 
						type="textarea" 
						name="description" 
						placeholder="Indica el reglamento particular, cronograma y detalles de los tramos..." 
						required 
					/>

					<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
						<Input 
							label="Plano / Trazado de Ruta (PDF/Imagen)" 
							type="file" 
							name="routeLayoutFile" 
							accept=".pdf,image/*"
							required 
						/>
						<Input 
							label="Plan de Seguridad y Emergencias (PDF)" 
							type="file" 
							name="securityPlanFile" 
							accept=".pdf"
							required 
						/>
						<Input 
							label="Póliza de Responsabilidad Civil (PDF)" 
							type="file" 
							name="liabilityInsuranceFile" 
							accept=".pdf"
							required 
						/>
					</div>

					<div class="border-t border-slate-border/50 pt-4 mt-2">
						<Input 
							label="Declaro bajo juramento que asumo las obligaciones delegadas de seguridad, coordinación sanitaria y cumplimiento técnico estipuladas por la Ley de Competición." 
							type="checkbox" 
							name="acceptDelegatedDuties" 
							required 
						/>
					</div>

					<div class="flex justify-end gap-3 mt-4 border-t border-slate-border/30 pt-6">
						<Button type="button" variant="outline" href="/private/applications">
							Cancelar
						</Button>
						<Button type="submit" variant="primary" id="submit-btn">
							Enviar Solicitud
						</Button>
					</div>
				</form>
			</Card>
		</div>
	</div>
</Layout>

<script>
	document.addEventListener('astro:page-load', () => {
		const form = document.getElementById('delegated-event-form') as HTMLFormElement;
		const submitBtn = document.getElementById('submit-btn');

		if (form) {
			form.addEventListener('submit', async (e) => {
				e.preventDefault();

				if (submitBtn) {
					submitBtn.setAttribute('disabled', 'true');
					submitBtn.textContent = 'Enviando...';
				}

				const formData = new FormData(form);
				
				// Set acceptDelegatedDuties checkbox value as string representation
				const isChecked = form.querySelector('input[name="acceptDelegatedDuties"]:checked') !== null;
				formData.set('acceptDelegatedDuties', isChecked ? 'true' : 'false');

				try {
					const res = await fetch('/api/private/applications/delegated-event', {
						method: 'POST',
						body: formData
					});

					const data = await res.json();
					if (data.success) {
						alert(data.message || 'Trámite registrado correctamente.');
						window.location.href = '/private/dashboard';
					} else {
						alert('Error: ' + (data.error?.message || 'Error desconocido al registrar evento.'));
						if (submitBtn) {
							submitBtn.removeAttribute('disabled');
							submitBtn.textContent = 'Enviar Solicitud';
						}
					}
				} catch (err) {
					console.error('Error submitting delegated event:', err);
					alert('Error de red en el servidor.');
					if (submitBtn) {
						submitBtn.removeAttribute('disabled');
						submitBtn.textContent = 'Enviar Solicitud';
					}
				}
			});
		}
	});
</script>
