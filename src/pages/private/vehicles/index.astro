---
import Layout from '@layouts/Layout.astro'
import Card from '@/components/ui/Card.astro'
import Button from '@/components/ui/Button.astro'
import DashboardSidebar from '@/components/ui/DashboardSidebar.astro'

const { user, citizenid, character } = Astro.locals

// Auth protection
if (!user || !citizenid || !character) {
	return Astro.redirect('/account')
}
---

<Layout title="Gestión de Vehículos | SAMF" description="Portal técnico de homologaciones, inspecciones y chasis autorizados en la SAMF.">
	<div class="max-w-[1440px] mx-auto px-4 md:px-8 py-12 flex flex-col md:flex-row gap-8">
		<!-- Sidebar Menu -->
		<DashboardSidebar activePath="/private/vehicles" role={user.role} />

		<!-- Main Panel Content -->
		<div class="flex-1 flex flex-col gap-6">
			<!-- Header Card -->
			<Card glow>
				<div class="flex items-center gap-3 mb-2">
					<span class="w-6 h-[2px] bg-brand-red rounded-sm"></span>
					<h1 class="text-xl font-bold uppercase tracking-wider font-racing text-white">Homologaciones y Catálogo Técnico</h1>
				</div>
				<p class="text-xs text-text-muted">
					Administra las certificaciones técnicas y chasis homologados de tus vehículos de competición.
				</p>
			</Card>

			<!-- Grid Options -->
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
				<!-- Homologación de Vehículo -->
				<Card hoverable class="flex flex-col justify-between h-full">
					<div>
						<div class="flex items-center justify-between mb-4">
							<span class="text-xs font-bold text-brand-red font-racing uppercase tracking-wider">Artículo 9</span>
							<span class="text-[10px] text-text-muted font-mono font-bold">1 Año Duración</span>
						</div>
						<h2 class="text-base font-bold text-white font-racing leading-tight mb-2">Homologar Vehículo (Ficha Técnica)</h2>
						<p class="text-xs text-text-muted leading-relaxed mb-6">
							Registra el número de chasis (VIN) y especificaciones de seguridad de tu vehículo para que un inspector realice la auditoría física (jaula antivuelco, extintor, arneses y ECU).
						</p>
					</div>
					<Button href="/private/vehicles/homologation" variant="primary" class="w-full text-center">
						Solicitar Homologación
					</Button>
				</Card>

				<!-- Inclusión en Catálogo -->
				{user.role === 'DIRECTOR_ESCUDERIA' || user.role === 'STAFF_ADMIN' || user.role === 'STAFF_DIRECTOR_GENERAL' ? (
					<Card hoverable class="flex flex-col justify-between h-full">
						<div>
							<div class="flex items-center justify-between mb-4">
								<span class="text-xs font-bold text-brand-red font-racing uppercase tracking-wider">Artículo 8.2</span>
								<span class="text-[10px] text-text-muted font-mono font-bold">Plazo 15 Días</span>
							</div>
							<h2 class="text-base font-bold text-white font-racing leading-tight mb-2">Inclusión de Modelo en Catálogo</h2>
							<p class="text-xs text-text-muted leading-relaxed mb-6">
								¿Tu equipo desea utilizar un nuevo modelo que no figura en la lista autorizada? Solicita la inclusión del modelo rellenando las especificaciones técnicas.
							</p>
						</div>
						<Button href="/private/vehicles/catalog-inclusion" variant="primary" class="w-full text-center">
							Solicitar Inclusión
						</Button>
					</Card>
				) : (
					<Card class="bg-slate-dark/30 border-dashed border-slate-border/50 opacity-60 flex flex-col justify-center items-center text-center p-6">
						<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-text-muted mb-3"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
						<h2 class="text-sm font-bold text-white font-racing uppercase tracking-wider mb-2">Inclusión de Modelo en Catálogo</h2>
						<p class="text-[10px] text-text-muted max-w-xs leading-normal">
							Este trámite técnico está restringido exclusivamente a Directores de Escudería oficiales (Art. 8.2).
						</p>
					</Card>
				)}
			</div>

		</div>
	</div>
</Layout>
