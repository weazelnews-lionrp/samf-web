---
import Layout from '@layouts/Layout.astro'
import Card from '@/components/ui/Card.astro'
import Button from '@/components/ui/Button.astro'
import Input from '@/components/ui/Input.astro'
import DashboardSidebar from '@/components/ui/DashboardSidebar.astro'

const { user, citizenid, character } = Astro.locals

// Auth protection
if (!user || !citizenid || !character) {
	return Astro.redirect('/account')
}

// Fetch approved vehicles for model selection options
let modelOptions = []
try {
	const apiUrl = new URL('/api/transparency/vehicles', Astro.url)
	const res = await fetch(apiUrl)
	const data = await res.json()
	if (data.success) {
		modelOptions = (data.catalog || []).map((v: any) => ({
			value: v.id,
			label: `${v.brand} ${v.model} [${v.category}]`
		}))
	}
} catch (err) {
	console.error('Error fetching catalog in homologation:', err)
}

const tireOptions = [
	{ value: 'Slick Competición Soft', label: 'Slick Competición Soft' },
	{ value: 'Slick Competición Medium', label: 'Slick Competición Medium' },
	{ value: 'Slick Competición Hard', label: 'Slick Competición Hard' },
	{ value: 'Lluvia / Mojado', label: 'Lluvia / Mojado' },
	{ value: 'Rally Mixto / Tierra', label: 'Rally Mixto / Tierra' }
]
---

<Layout title="Homologar Vehículo | SAMF" description="Ficha técnica de solicitud de homologación e inspección de seguridad del chasis del vehículo (Art. 9.1).">
	<div class="max-w-[1440px] mx-auto px-4 md:px-8 py-12 flex flex-col md:flex-row gap-8">
		<!-- Sidebar Menu -->
		<DashboardSidebar activePath="/private/vehicles" role={user.role} />

		<!-- Main Panel Content -->
		<div class="flex-1 flex flex-col gap-6">
			<!-- Back Link -->
			<div>
				<Button href="/private/vehicles" variant="outline" size="sm" class="flex items-center gap-2">
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
					Volver a Vehículos
				</Button>
			</div>

			<!-- Form Card -->
			<Card glow>
				<div class="flex items-center gap-3 mb-2 border-b border-slate-border/50 pb-3">
					<span class="w-6 h-[2px] bg-brand-red rounded-sm"></span>
					<h1 class="text-xl font-bold uppercase tracking-wider font-racing text-white">Solicitud de Homologación de Vehículo (Art. 9.1)</h1>
				</div>
				
				<p class="text-xs text-text-muted mb-8 leading-relaxed">
					Introduce el número de chasis/bastidor (VIN) y marca las medidas de seguridad instaladas. Tras el registro, un Inspector Técnico de la SAMF auditará el vehículo físicamente (Art. 9.2).
				</p>

				<form id="homologation-form" class="flex flex-col gap-6">
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						<Input 
							label="Modelo Homologado" 
							type="select" 
							name="modelId" 
							placeholder="Selecciona un modelo del catálogo..."
							options={modelOptions}
							required 
						/>
						<Input 
							label="Número de Chasis / Bastidor (VIN)" 
							type="text" 
							name="chassisNumber" 
							placeholder="Ej. VIN-BENEFACTOR-991278" 
							required 
						/>
					</div>

					<div class="border-t border-slate-border/50 pt-4">
						<h3 class="text-xs font-bold text-brand-red font-racing uppercase tracking-wider mb-4">Checklist de Medidas de Seguridad Obligatorias (Art. 9.2)</h3>
						
						<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
							<Input 
								label="Jaula Antivuelco de Competición Homologada" 
								type="checkbox" 
								name="rollCage" 
							/>
							<Input 
								label="Sistema de Extinción de Incendios Activo" 
								type="checkbox" 
								name="fireExtinguisher" 
							/>
							<Input 
								label="Arnés de Seguridad Profesional de 4 Puntos" 
								type="checkbox" 
								name="harnessFourPoints" 
							/>
							<Input 
								label="Asiento (Backet) con Certificación FIA Vigente" 
								type="checkbox" 
								name="certifiedSeat" 
							/>
							<Input 
								label="Electrónica / Centralita de Control de Competición (ECU)" 
								type="checkbox" 
								name="controlECU" 
							/>
							<Input 
								label="Compuesto de Neumáticos Empleado" 
								type="select" 
								name="tiresCategory" 
								placeholder="Selecciona compuesto..."
								options={tireOptions}
								required 
							/>
						</div>
					</div>

					<div class="flex justify-end gap-3 mt-4 border-t border-slate-border/30 pt-6">
						<Button type="button" variant="outline" href="/private/vehicles">
							Cancelar
						</Button>
						<Button type="submit" variant="primary" id="submit-btn">
							Enviar Solicitud
						</Button>
					</div>
				</form>
			</Card>
		</div>
	</div>
</Layout>

<script>
	document.addEventListener('astro:page-load', () => {
		const form = document.getElementById('homologation-form') as HTMLFormElement;
		const submitBtn = document.getElementById('submit-btn');

		if (form) {
			form.addEventListener('submit', async (e) => {
				e.preventDefault();

				if (submitBtn) {
					submitBtn.setAttribute('disabled', 'true');
					submitBtn.textContent = 'Enviando...';
				}

				const formData = new FormData(form);
				const payload = {
					modelId: formData.get('modelId'),
					chassisNumber: formData.get('chassisNumber'),
					safetyChecks: {
						rollCage: form.querySelector('input[name="rollCage"]:checked') !== null,
						fireExtinguisher: form.querySelector('input[name="fireExtinguisher"]:checked') !== null,
						harnessFourPoints: form.querySelector('input[name="harnessFourPoints"]:checked') !== null,
						certifiedSeat: form.querySelector('input[name="certifiedSeat"]:checked') !== null,
						controlECU: form.querySelector('input[name="controlECU"]:checked') !== null,
						tiresCategory: formData.get('tiresCategory'),
					}
				};

				try {
					const res = await fetch('/api/private/vehicles/homologation', {
						method: 'POST',
						headers: {
							'Content-Type': 'application/json'
						},
						body: JSON.stringify(payload)
					});

					const data = await res.json();
					if (data.success) {
						alert(data.message || 'Trámite de homologación registrado.');
						window.location.href = '/private/dashboard';
					} else {
						alert('Error: ' + (data.error?.message || 'Error desconocido al registrar homologación.'));
						if (submitBtn) {
							submitBtn.removeAttribute('disabled');
							submitBtn.textContent = 'Enviar Solicitud';
						}
					}
				} catch (err) {
					console.error('Error submitting homologation:', err);
					alert('Error de red en el servidor.');
					if (submitBtn) {
						submitBtn.removeAttribute('disabled');
						submitBtn.textContent = 'Enviar Solicitud';
					}
				}
			});
		}
	});
</script>
