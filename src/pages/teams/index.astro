---
import Layout from '@layouts/Layout.astro'
import Card from '@/components/ui/Card.astro'
import Button from '@/components/ui/Button.astro'
import StatusBadge from '@/components/ui/StatusBadge.astro'
import Input from '@/components/ui/Input.astro'

const search = Astro.url.searchParams.get('search') || ''

// Fetch from API
const apiUrl = new URL('/api/teams', Astro.url)
if (search) {
	apiUrl.searchParams.set('search', search)
}

let teams = []
try {
	const res = await fetch(apiUrl)
	const data = await res.json()
	if (data.success) {
		teams = data.teams
	}
} catch (err) {
	console.error('Error fetching teams from API:', err)
}
---

<Layout title="Directorio de Escuderías | SAMF" description="Directorio y catálogo oficial de escuderías y equipos de la San Andreas Motorsports Federation (SAMF).">
	<div class="max-w-[1440px] mx-auto px-4 md:px-8 py-12">
		<!-- Page Header -->
		<div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
			<div>
				<div class="flex items-center gap-3 mb-2">
					<span class="w-8 h-[3px] bg-brand-red rounded-sm"></span>
					<h1 class="text-3xl font-extrabold uppercase tracking-wider font-racing text-white">Directorio de Escuderías</h1>
				</div>
				<p class="text-sm text-text-muted max-w-xl">
					Consulta el registro público oficial de todos los equipos autorizados a participar en las competiciones estatales de la SAMF (Art. 6.2 y 11.1).
				</p>
			</div>
			
			<!-- Search Form -->
			<form method="GET" class="flex items-center gap-2 w-full md:w-80">
				<Input 
					type="text" 
					name="search" 
					placeholder="Buscar escudería..." 
					value={search}
					class="shrink"
				/>
				<Button type="submit" variant="primary">
					Buscar
				</Button>
			</form>
		</div>

		{teams.length === 0 ? (
			<Card class="text-center py-16">
				<p class="text-text-muted mb-4">No se encontraron escuderías registradas o que coincidan con la búsqueda.</p>
				{search && (
					<Button href="/teams" variant="outline" size="sm">
						Limpiar búsqueda
					</Button>
				)}
			</Card>
		) : (
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				{teams.map((team: any) => (
					<Card hoverable glow class="flex flex-col h-full justify-between">
						<div>
							<!-- Header Info -->
							<div class="flex items-start justify-between gap-4 mb-6">
								<div class="flex items-center gap-4">
									{team.logo ? (
										<img 
											src={team.logo} 
											alt={`Logo de ${team.name}`} 
											class="w-16 h-16 rounded-lg object-contain bg-slate-black/50 border border-slate-border p-1"
										/>
									) : (
										<div class="w-16 h-16 rounded-lg bg-slate-gray/50 flex items-center justify-center text-text-muted font-bold text-xl border border-slate-border">
											{team.name.charAt(0)}
										</div>
									)}
									<div>
										<h2 class="text-lg font-bold text-white font-racing leading-tight">{team.name}</h2>
										<span class="text-xs text-text-muted font-medium">
											Director: {team.directorName || 'Sin director asignado'}
										</span>
									</div>
								</div>
								
								<StatusBadge status={team.status} />
							</div>

							<!-- Visual Badge & Stats -->
							<div class="flex items-center justify-between border-t border-slate-border/50 pt-4 mt-auto">
								<div class="flex items-center gap-2">
									<span class="text-xs text-text-muted">Color distintivo:</span>
									<span 
										class="w-6 h-6 rounded-md border border-white/10" 
										style={{ backgroundColor: team.visualBadge || '#ffffff' }}
										title={team.visualBadge}
									></span>
								</div>
								<div class="text-right">
									<span class="text-[10px] text-text-muted uppercase tracking-wider block">Puntos Campeonato</span>
									<span class="text-xl font-extrabold text-white font-racing">{team.points} pts</span>
								</div>
							</div>
						</div>

						<div class="mt-6 pt-4 border-t border-slate-border/30">
							<Button href={`/teams/${team.id}`} variant="outline" class="w-full text-center">
								Ver Ficha Completa
							</Button>
						</div>
					</Card>
				))}
			</div>
		)}
	</div>
</Layout>
